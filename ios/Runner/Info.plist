	<string>Nkap Health needs microphone access to record voice notes in chat.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Nkap Health needs access to your photo library to upload medical documents and images.</string>
	<key>NSDocumentsFolderUsageDescription</key>
	<string>Nkap Health needs access to your documents to upload medical records.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
