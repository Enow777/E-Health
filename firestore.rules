rules_version = '2';
service cloud.firestore {
  match /databases/ehealthdatabase/documents {

    // FCM tokens — each user writes and reads their own token only.
    match /userTokens/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Role selection — user can create/read their own role document.
    match /userRoles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Doctor private profile — only the doctor themselves can read/write.
    match /doctorProfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Public doctor directory — any signed-in user can read.
    // Authenticated users can update (needed for rating transactions).
    // Only the doctor or admin can create/delete.
    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.uid == doctorId;
      allow update: if request.auth != null;
    }

    // Patient profiles — patient can read/write their own.
    match /patients/{patientId} {
      allow read, write: if request.auth != null && request.auth.uid == patientId;
    }

    // Appointments: patient owns, doctor can read/update theirs.
    match /appointments/{appointmentId} {
      allow read, delete: if request.auth != null
          && resource.data.patientId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.patientId == request.auth.uid;
      // Patient can update (ratings, patientInCall).
      allow update: if request.auth != null
          && resource.data.patientId == request.auth.uid;
      // Doctor can read and update their own appointments (status, callActive).
      allow read, update: if request.auth != null
          && resource.data.doctorId == request.auth.uid;
    }

    // Ratings: a patient can submit exactly one rating per appointment.
    // The doc ID is {patientId}_{appointmentId}.
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
          && request.resource.data.patientId == request.auth.uid;
      // No updates or deletes — ratings are immutable once submitted.
    }

    // Chat conversations: participants can read/write.
    // Messages subcollection: participants can read/write.
    match /chats/{chatId} {
      allow read, write: if request.auth != null
          && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
          && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
            && request.resource.data.senderId == request.auth.uid;
        allow update: if request.auth != null
            && resource.data.senderId == request.auth.uid;
      }
    }

    // Medical records: patient can create and read their own.
    match /medicalRecords/{recordId} {
      allow read: if request.auth != null
          && resource.data.patientId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.patientId == request.auth.uid;
    }

    // Saved doctors: patient can create, read, and delete their own.
    match /savedDoctors/{saveId} {
      allow read, delete: if request.auth != null
          && resource.data.patientId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.patientId == request.auth.uid;
    }

    // Record shares: patient can create and read their own.
    match /recordShares/{shareId} {
      allow read: if request.auth != null
          && resource.data.patientId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.patientId == request.auth.uid;
    }

    // Prescriptions: patient can create, read, and delete their own.
    match /prescriptions/{prescriptionId} {
      allow read, delete: if request.auth != null
          && resource.data.patientId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.patientId == request.auth.uid;
    }

    // Notifications: patient can create, read, and update (mark read) their own.
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null
          && resource.data.patientId == request.auth.uid;
      allow create: if request.auth != null
          && request.resource.data.patientId == request.auth.uid;
    }
  }
}
